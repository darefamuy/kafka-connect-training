# =============================================================================
# HCI Pharma Kafka Connect — Environment Variables
# Copy this file to .env and fill in your Confluent Cloud credentials.
#
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d
#
# NEVER commit .env to source control — it contains API secrets.
# =============================================================================

# ── Confluent Cloud Kafka cluster ─────────────────────────────────────────────
# Cluster ID — found in: Confluent Cloud > Cluster > Cluster Settings
# Used by create-topics.sh to select the correct cluster automatically.
# Format: lkc-xxxxxx
CONFLUENT_CLUSTER_ID=lkc-xxxxxx

# Bootstrap server — found in: Confluent Cloud > Cluster > Cluster Settings > Endpoints
CONFLUENT_BOOTSTRAP_SERVERS=pkc-xxxxx.europe-west1.gcp.confluent.cloud:9092

# ── Confluent Cloud API Key (Kafka) ───────────────────────────────────────────
# Create in: Confluent Cloud > Cluster > API Keys > Add Key
CONFLUENT_API_KEY=YOUR_KAFKA_API_KEY
CONFLUENT_API_SECRET=YOUR_KAFKA_API_SECRET

# ── Confluent Schema Registry ─────────────────────────────────────────────────
# Found in: Confluent Cloud > Schema Registry > API Endpoint
CONFLUENT_SCHEMA_REGISTRY_URL=https://psrc-xxxxx.europe-west1.aws.confluent.cloud

# ── Confluent Schema Registry API Key ────────────────────────────────────────
# Create in: Confluent Cloud > Schema Registry > API Keys > Add Key
CONFLUENT_SR_API_KEY=YOUR_SR_API_KEY
CONFLUENT_SR_API_SECRET=YOUR_SR_API_SECRET
